# Switchboard — environment variables
# Copy to `.env.local` for local dev. Everything here is OPTIONAL: the app and
# `next build` work with no env set (features degrade gracefully). Secrets are
# server-only; only NEXT_PUBLIC_* values are exposed to the browser.

# Newsletter — Supabase (Phase 3)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Contact / lead forms — n8n webhook (Phase 2.7)
N8N_WEBHOOK_URL=

# Booking — Cal.com link, e.g. switchboard/15min
NEXT_PUBLIC_CALCOM_LINK=
