# Switchboard — environment variables
# Copy to `.env.local` for local dev. Everything here is OPTIONAL: the app and
# `next build` work with no env set (features degrade gracefully). Secrets are
# server-only; only NEXT_PUBLIC_* values are exposed to the browser.

# Newsletter — Supabase. URL + anon key are public; the service-role key is
# server-only (used by src/app/api/newsletter/route.ts). Apply supabase/schema.sql
# first. With these unset the signup still works — it just isn't stored.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Contact / lead forms — n8n webhook (Phase 2.7)
N8N_WEBHOOK_URL=

# Booking — Cal.com link, e.g. switchboard/15min
NEXT_PUBLIC_CALCOM_LINK=

# Canonical site origin for absolute URLs in <meta> tags (SEO/Open Graph).
# Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=
